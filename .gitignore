# Python
__pycache__/
*.py[cod]
*$py.class
*.so
*.egg-info/
.eggs/
build/
dist/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Virtual environments
venv/
.venv/
env/

# Jupyter
.ipynb_checkpoints/

# IDE
.vscode/
.idea/
*.swp
.DS_Store

# Data — never commit raw images or large binaries
# Anchored at repo root so it doesn't match src/data/
/data/
*.nii
*.nii.gz
*.dcm
*.npy
*.npz
*.h5
*.pkl
!docs/**/*.pkl

# Outputs — checkpoints, logs, predictions
*.pth
*.ckpt
*.safetensors

# SLURM stdout/stderr
slurm-*.out
/outputs/
/results/*.png
/results/*.pdf

# Credentials — explicit blocks even though we never write these
.env
.env.*
*.pem
.git-credentials
.netrc
secrets.yaml

# Local-only scratch (Chinese notes, etc.)
scratch/
*.local.md

# Collaboration / agent-coordination docs — kept locally but not on GitHub
# (GitHub repo holds only DL code: src/, scripts/, configs/, slurm/templates/, requirements.txt, README.md)
CLAUDE.md
AGENTS.md
todo.md
experiment_logs.md
docs/handoff.md
docs/decision_log.md
docs/technical.md
docs/dataset.md
docs/borrowed_ideas.md
docs/reviews/

# Lab-only reference copy of upstream source (e.g., PRISM); never commit
prism_reference/
